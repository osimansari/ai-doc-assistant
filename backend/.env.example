# OpenAI/LLM
OPENAI_BASE_URL=https://instance.openai.azure.com/openai/v1
OPENAI_API_KEY=
LLM_MODEL=gpt-5.1-chat

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_doc_assistant

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# Embeddings
EMBEDDING_BASE_URL=https://instance.openai.azure.com/openai/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Retrieval
RETRIEVAL_TOP_K=5

# File storage
UPLOAD_DIR=data/documents
